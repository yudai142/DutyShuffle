# Render.comで提供されるPostgreSQL接続URL
# Render.comダッシュボード > PostgreSQL > External Database URL をコピーして貼り付け
DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# PHP設定
DB_HOST=postgresql-server
DB_PORT=5432
DB_NAME=database_name
DB_USER=username
DB_PASS=password

# アプリケーション設定
APP_ENV=production
APP_DEBUG=false
